{
  "backend": "github",
  "defaultPickFrom": "Todo",
  "defaultPickTo": "In Progress",
  "defaultFinishTo": "Done",
  "leaseMinutes": 60,
  "archive": {
    "onStatuses": [
      "Done"
    ]
  },
  "worker": {
    "defaultAgent": null,
    "workspaceMode": "current",
    "completion": {
      "commit": "inspect",
      "integration": "none"
    },
    "worktreeRoot": "{repoParent}/{repo}.worktrees",
    "branchFormat": "wrighty-worker/{id}-{title}",
    "worktreeNameFormat": "{id}-{title}"
  },
  "github": {
    "repository": "owner/repository",
    "projectOwner": "owner",
    "projectNumber": 1,
    "linkRepository": true,
    "claimHistoryLimit": 10,
    "gitHubHost": "github.com"
  }
}
