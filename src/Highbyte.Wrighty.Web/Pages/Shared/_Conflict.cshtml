@model ConflictPageModel
<article class="detail conflict" data-item-id="@Model.Current.Id">
  <header class="detail-header"><div><span class="display-id">@Model.Current.DisplayId</span><h2 tabindex="-1">Update conflict</h2></div><button type="button" class="close-panel" aria-label="Close details">×</button></header>
  <p class="error" role="alert"><strong>UPDATE_CONFLICT</strong> This item changed after you began editing. Your draft has not been saved.</p>
  <div class="comparison"><section><h3>Your draft</h3><strong>@Model.SubmittedTitle</strong><p>@Model.SubmittedStatus · @(Model.SubmittedPriority ?? "No priority")</p><pre>@Model.SubmittedBody</pre></section><section><h3>Current version</h3><strong>@Model.Current.Title</strong><p>@(Model.Current.Status ?? "No status") · @(Model.Current.Priority ?? "No priority")</p><pre>@Model.Current.Body</pre></section></div>
  <form hx-get="/?handler=Edit" hx-target="#item-panel" hx-swap="innerHTML"><input type="hidden" name="id" value="@Model.Current.Id"><button class="primary">Reload current version</button></form>
</article>
