@model ItemPageModel
<article class="detail edit-detail" data-item-id="@Model.Id">
  <header class="detail-header"><div><span class="display-id">@Model.DisplayId</span><h2 tabindex="-1">Edit work item</h2></div><button type="button" class="close-panel" aria-label="Close details">×</button></header>
  @if (Model.Notice is not null){<p class="notice" role="status">@Model.Notice</p>}
  @if (Model.ErrorCode is not null){<p class="error" role="alert"><strong>@Model.ErrorCode</strong> @Model.ErrorMessage</p>}
  <p id="stale-edit-notice" class="notice" role="status" hidden>The dashboard changed while this draft was open. Save will verify that this item is still current.</p>
  <partial name="_ResumeAddress" model="Model" />
  <form class="edit-form" hx-post="/?handler=Save" hx-target="#item-panel" hx-swap="innerHTML" data-has-resume-address="@Model.HasResumeAddress.ToString().ToLowerInvariant()">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id">
    <input type="hidden" name="expectedRevision" value="@Model.Revision">
    <input type="hidden" name="expectedClaimGeneration" value="@Model.ClaimGeneration">
    <label>Title <input name="title" value="@Model.Title" maxlength="256" required></label>
    <label>Status <select name="status">@foreach(var status in Model.Statuses){<option value="@status" selected="@(string.Equals(status, Model.Status, StringComparison.OrdinalIgnoreCase))">@status</option>}</select></label>
    <label>Priority <select name="priority"><option value="">None</option>@foreach(var priority in Model.Priorities){<option value="@priority" selected="@(string.Equals(priority, Model.Priority, StringComparison.OrdinalIgnoreCase))">@priority</option>}</select></label>
    <fieldset class="worker-settings">
      <legend>Autonomous worker</legend>
      <label class="checkbox-field">
        <input type="checkbox" name="automationEligible" value="true" checked="@Model.AutomationEligible">
        <span><strong>Eligible for worker processing</strong><small>Stores <code>wrighty-auto: true</code>. Workers ignore the item when this is off.</small></span>
      </label>
      <label>Preferred agent
        <select name="preferredAgent">
          <option value="">No item preference</option>
          @foreach (var agent in new[] { "claude", "codex", "copilot" })
          {
            <option value="@agent" selected="@(string.Equals(agent, Model.PreferredAgent, StringComparison.OrdinalIgnoreCase))">@char.ToUpperInvariant(agent[0])@agent[1..]</option>
          }
        </select>
        <small>Stores <code>wrighty-agent</code>. A worker-level <code>--agent</code> overrides this choice.</small>
      </label>
    </fieldset>
    <label>Markdown body <textarea name="body" rows="18">@Model.Body</textarea></label>
    @if (Model.HasResumeAddress && Model.ResumeAgentLabel is not null)
    {
      <p class="handback-hint">Choose <strong>Save and queue for worker</strong> to let a continuous worker resume the recorded session. Choose <strong>Save and hand back to @Model.ResumeAgentLabel</strong> for interactive continuation.</p>
    }
    <div class="actions edit-actions">
      <div class="actions-secondary">
        <button class="has-tooltip" name="action" value="release" formnovalidate aria-describedby="edit-release-help" data-tooltip="Discard this draft and release the claim without saving field changes. A recorded agent session remains available for later resume.">Release without saving</button>
        <span id="edit-release-help" class="visually-hidden">Discard this draft and release the claim without saving field changes. A recorded agent session remains available for later resume.</span>
        <button type="button" class="cancel-edit">Cancel</button>
      </div>
      <div class="actions-primary">
        @if (Model.HasResumeAddress)
        {
          <details class="action-menu">
            <summary>More actions…</summary>
            <div class="action-menu-popover">
              <button class="has-tooltip" name="action" value="save-release" aria-describedby="save-release-help" data-tooltip="Save these changes and release the claim. The recorded agent session remains available for later resume." data-confirm-message="Save and release this claim? The item returns to the pool; the recorded agent session remains available.">Save and release</button>
              <span id="save-release-help" class="visually-hidden">Save these changes and release the claim. The recorded agent session remains available for later resume.</span>
            </div>
          </details>
        }
        else
        {
          <button class="has-tooltip" name="action" value="save-release" aria-describedby="save-release-help" data-tooltip="Save these changes, then release the claim for another worker.">Save and release</button>
          <span id="save-release-help" class="visually-hidden">Save these changes, then release the claim for another worker.</span>
        }
        <button class="has-tooltip" name="action" value="finish" aria-describedby="finish-help" data-tooltip="Save these changes, move the item to the configured finished status, and release its claim.">Finish</button>
        <span id="finish-help" class="visually-hidden">Save these changes, move the item to the configured finished status, and release its claim.</span>
        <button name="action" value="save">Save</button>
        @if (Model.HasResumeAddress && Model.ResumeAgentLabel is not null)
        {
          <button class="primary has-tooltip" name="action" value="save-queue" aria-describedby="queue-help" data-tooltip="Save these changes, end human ownership, and queue the recorded session for a continuous worker.">Save and queue for worker</button>
          <span id="queue-help" class="visually-hidden">Save these changes and queue the recorded agent session for a continuous worker.</span>
          <button class="primary has-tooltip" name="action" value="save-handback" aria-describedby="handback-help" data-tooltip="Save these changes, rotate the claim to the recorded agent session, and show its fenced resume command.">Save and hand back to @Model.ResumeAgentLabel</button>
          <span id="handback-help" class="visually-hidden">Save these changes, rotate the claim to the recorded agent session, and show its fenced resume command.</span>
        }
      </div>
    </div>
  </form>
</article>
