@model BoardCardModel
@{
  var claimClass = Model.ClaimState switch
  {
    ClaimOwnershipState.OwnedByCurrent => "claimed claimed-current",
    ClaimOwnershipState.HeldByOther => "claimed claimed-other",
    _ => string.Empty
  };
  var activityClass = Model.Activity switch
  {
    WorkItemActivities.NeedsAttention => "activity-needs-attention",
    WorkItemActivities.AgentActive => "activity-agent-active",
    WorkItemActivities.Queued => "activity-queued",
    WorkItemActivities.PausedSession => "activity-paused",
    WorkItemActivities.Completed => "activity-completed",
    _ => string.Empty
  };
  var activityLabel = Model.Activity switch
  {
    WorkItemActivities.NeedsAttention => "Needs attention",
    WorkItemActivities.AgentActive => $"{Model.AgentTypeLabel ?? "Agent"} active",
    WorkItemActivities.Queued => "Queued to resume",
    WorkItemActivities.PausedSession => "Paused session available",
    WorkItemActivities.Completed => "Completed",
    WorkItemActivities.HumanEditing => "Human editing",
    WorkItemActivities.Ready => "Ready for worker",
    _ => null
  };
}
<button type="button" class="card @claimClass @activityClass" title="@Model.Title" data-item-id="@Model.Id"
        data-filter-text="@Model.DisplayId @Model.Title @Model.Status @Model.Priority @Model.ClaimantKindLabel @Model.AgentTypeLabel @activityLabel"
        hx-get="/?handler=Item&amp;id=@Uri.EscapeDataString(Model.Id)"
        hx-target="#item-panel" hx-swap="innerHTML">
  <span class="card-top"><span class="display-id">@Model.DisplayId</span>@if (Model.Priority is not null){<span class="priority">@Model.Priority</span>}</span>
  <span class="card-title">@Model.Title</span>
  @if (activityLabel is not null)
  {
    <span class="activity-badge">@activityLabel</span>
  }
  <span class="card-meta">
    @if (Model.ClaimantKindLabel is not null){<span class="claimant-badge">@(Model.AgentTypeLabel ?? Model.ClaimantKindLabel)</span>}
    @if (Model.HasRecordedWorktree){<span class="worktree-badge" title="A worker worktree is recorded for this item">⌥ worktree</span>}
    <span>@Model.ClaimLabel@if (Model.Archived){<text> · Archived</text>}</span>
  </span>
</button>
