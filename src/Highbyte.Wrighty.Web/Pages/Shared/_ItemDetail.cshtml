@model ItemPageModel
<article class="detail" data-item-id="@Model.Id">
  <header class="detail-header">
    <div><span class="display-id">@Model.DisplayId</span><h2 tabindex="-1">@Model.Title</h2></div>
    <button type="button" class="close-panel" aria-label="Close details">×</button>
  </header>
  @if (Model.Notice is not null){<p class="notice" role="status">@Model.Notice</p>}
  @if (Model.ErrorCode is not null){<p class="error" role="alert"><strong>@Model.ErrorCode</strong> @Model.ErrorMessage</p>}
  @if (Model.WebMutationProtectionMessage is not null){<p class="notice" role="status">@Model.WebMutationProtectionMessage</p>}
  @if (Model.Activity == WorkItemActivities.NeedsAttention)
  {
    <aside class="worker-state-callout needs-attention" role="status">
      <strong>Agent needs attention</strong>
      <span>The recorded session is paused. Clarify the requirements, then queue it for a continuous worker or continue it explicitly.</span>
    </aside>
  }
  else if (Model.Activity == WorkItemActivities.Queued)
  {
    <aside class="worker-state-callout queued" role="status">
      <strong>Queued to resume</strong>
      <span>A continuous worker can claim this item and resume its recorded agent session.</span>
    </aside>
  }
  else if (Model.Activity == WorkItemActivities.AgentActive)
  {
    <aside class="worker-state-callout agent-active" role="status">
      <strong>@(Model.AgentTypeLabel ?? "Agent") active</strong>
      <span>The agent claim is active. Claim state does not guarantee that the operating-system process is still alive.</span>
    </aside>
  }
  else if (Model.Activity == WorkItemActivities.Completed)
  {
    <aside class="worker-state-callout completed" role="status">
      <strong>Completed</strong>
      <span>The agent finished this item and the work landed. The recorded session can still be reopened, but the usual next step is to finalize or archive it.</span>
    </aside>
  }
  @if (Model.LastRun is { } lastRun)
  {
    <aside class="last-run last-run-@lastRun.Label" role="status">
      <strong>Last run: @lastRun.Label</strong>
      @if (lastRun.EndedAt is { } endedAt)
      {
        <span class="last-run-when">Ended @endedAt.ToString("u")</span>
      }
      @if (!string.IsNullOrWhiteSpace(lastRun.FinalMessage))
      {
        <pre class="last-run-message">@lastRun.FinalMessage</pre>
      }
    </aside>
  }
  <dl class="metadata">
    <div><dt>Status</dt><dd>@(Model.Status ?? "No status")</dd></div>
    <div><dt>Priority</dt><dd>@(Model.Priority ?? "None")</dd></div>
    <div><dt>Worker eligible</dt><dd>@(Model.AutomationEligible ? "Yes" : "No")</dd></div>
    <div><dt>Preferred agent</dt><dd>@(Model.PreferredAgent is null ? "No item preference" : char.ToUpperInvariant(Model.PreferredAgent[0]) + Model.PreferredAgent[1..])</dd></div>
    <div><dt>Worker activity</dt><dd>@Model.Activity.Replace('-', ' ')</dd></div>
    @if (Model.ClaimantKindLabel is not null)
    {
      <div><dt>Claimant</dt><dd>@Model.ClaimantKindLabel</dd></div>
    }
    @if (Model.AgentTypeLabel is not null)
    {
      <div><dt>Agent</dt><dd>@Model.AgentTypeLabel</dd></div>
    }
    @if (Model.ClaimState != ClaimOwnershipState.Unclaimed && Model.ClaimantId is not null)
    {
      <div class="metadata-technical" data-copy-scope>
        <dt>Claimant ID</dt>
        <dd class="inspectable-value">
          <code id="claimant-id-value" class="inspectable-value-text">@Model.ClaimantId</code>
          <span class="inspectable-value-actions">
            <button type="button" class="expand-value-button" data-expand-target="claimant-id-value" aria-controls="claimant-id-value" aria-expanded="false">Show full</button>
            <button type="button" class="copy-button" data-copy-target="claimant-id-value" data-copy-name="Claimant ID">Copy</button>
          </span>
          <span class="copy-feedback" role="status" aria-live="polite"></span>
        </dd>
      </div>
    }
    <div><dt>Claim</dt><dd>@Model.ClaimLabel</dd></div>
    @if (Model.Workspace is { Removed: true })
    {
      @* The recorded worktree was removed (e.g. cleaned up after completion). The durable session
         is kept for the record, but the branch/path no longer exist, so collapse them into one
         honest line rather than surfacing a dead path. *@
      <div><dt>Worktree</dt><dd>Removed — no longer present on this host</dd></div>
    }
    else if (Model.Workspace is { } workspace)
    {
      @if (workspace.Branch is not null)
      {
        <div><dt>Worker branch</dt><dd><code>@workspace.Branch</code></dd></div>
      }
      @if (workspace.StatusAvailable)
      {
        <div><dt>Working tree</dt><dd>@(workspace.Dirty ? "Dirty (uncommitted changes)" : "Clean")</dd></div>
        <div><dt>Branch state</dt><dd>@(workspace.Merged ? "Merged into HEAD" : "Unmerged")</dd></div>
      }
      else
      {
        <div><dt>Worktree status</dt><dd>@workspace.Unavailable</dd></div>
      }
      <div class="metadata-technical" data-copy-scope>
        <dt>Workspace path</dt>
        <dd class="inspectable-value">
          <code id="workspace-path-value" class="inspectable-value-text">@workspace.Path</code>
          <span class="inspectable-value-actions">
            <button type="button" class="expand-value-button" data-expand-target="workspace-path-value" aria-controls="workspace-path-value" aria-expanded="false">Show full</button>
            <button type="button" class="copy-button" data-copy-target="workspace-path-value" data-copy-name="Workspace path">Copy</button>
          </span>
          <span class="copy-feedback" role="status" aria-live="polite"></span>
        </dd>
      </div>
    }
  </dl>
  @if (Model.EffectiveFields.Count > 0)
  {
    <details class="custom-fields">
      <summary>Custom fields (@Model.EffectiveFields.Count)</summary>
      <dl class="custom-field-list">
        @{ var fieldIndex = 0; }
        @foreach (var field in Model.EffectiveFields.OrderBy(pair => pair.Key, StringComparer.Ordinal))
        {
          var fieldValueId = $"custom-field-value-{fieldIndex++}";
          <div data-copy-scope>
            <dt>@field.Key</dt>
            <dd class="custom-field-value">
              <code id="@fieldValueId">@field.Value</code>
              <button type="button" class="copy-button" data-copy-target="@fieldValueId" data-copy-name="@field.Key custom field">Copy</button>
              <span class="copy-feedback" role="status" aria-live="polite"></span>
            </dd>
          </div>
        }
      </dl>
    </details>
  }
  <partial name="_ResumeAddress" model="Model" />
  <partial name="_CompleteWorktree" model="Model" />
  @if (Model.RawFrontmatter is not null)
  {
    <details class="frontmatter"><summary>Frontmatter</summary><pre><code class="language-yaml">@Model.RawFrontmatter</code></pre></details>
  }
  <div class="tabs" role="tablist" aria-label="Markdown view">
    <button id="rendered-tab" type="button" class="tab active" role="tab" aria-selected="true" aria-controls="rendered-panel">Rendered</button>
    <button id="raw-tab" type="button" class="tab" role="tab" aria-selected="false" aria-controls="raw-panel" tabindex="-1">Raw Markdown</button>
  </div>
  <div id="rendered-panel" class="markdown" role="tabpanel" aria-labelledby="rendered-tab" hx-disable>@Model.RenderedBody</div>
  <pre id="raw-panel" class="raw" role="tabpanel" aria-labelledby="raw-tab" hidden><code>@Model.Body</code></pre>
  <footer class="actions">
    @if (Model.Archived)
    {
      <div class="actions-primary">
        <form hx-post="/?handler=Unarchive" hx-target="#item-panel" hx-swap="innerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="primary">Unarchive</button></form>
      </div>
    }
    else if (Model.ClaimState == ClaimOwnershipState.Unclaimed)
    {
      <div class="actions-secondary">
        <form hx-post="/?handler=Claim" hx-target="#item-panel" hx-swap="innerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="@(Model.CanQueueForWorker ? null : "primary")">Claim for editing</button></form>
        <form hx-post="/?handler=ClaimAndArchive" hx-target="#item-panel" hx-swap="innerHTML" data-confirm-message="Archive this item? Wrighty claims it, moves it to the archive, and preserves the recorded session.">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="danger has-tooltip" aria-describedby="archive-unclaimed-help" data-tooltip="Claim and archive this item in one step. The recorded session is preserved.">Archive</button></form>
        <span id="archive-unclaimed-help" class="visually-hidden">Claim and archive this item in one step. The recorded session is preserved.</span>
      </div>
      @if (Model.CanQueueForWorker)
      {
        <div class="actions-primary">
          <form hx-post="/?handler=QueueForWorker" hx-target="#item-panel" hx-swap="innerHTML" data-confirm-message="Queue this paused session for a continuous worker? The work item instructions will not be changed.">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="primary">Queue for worker</button></form>
        </div>
      }
    }
    else if (Model.ClaimState == ClaimOwnershipState.OwnedByCurrent && !Model.WebMutationProtected)
    {
      <div class="actions-secondary">
        @if (Model.HasResumeAddress)
        {
          <form hx-post="/?handler=Release" hx-target="#item-panel" hx-swap="innerHTML" data-confirm-message="Release this claim? The item returns to the pool; the recorded agent session remains available.">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="has-tooltip" aria-describedby="release-help" data-tooltip="Release the claim. The recorded agent session remains available for later resume.">Release claim</button></form>
          <span id="release-help" class="visually-hidden">Release the claim. The recorded agent session remains available for later resume.</span>
        }
        else
        {
          <form hx-post="/?handler=Release" hx-target="#item-panel" hx-swap="innerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="has-tooltip" aria-describedby="release-help" data-tooltip="Release the claim so another worker can claim this item.">Release</button></form>
          <span id="release-help" class="visually-hidden">Release the claim so another worker can claim this item.</span>
        }
        <form hx-post="/?handler=Archive" hx-target="#item-panel" hx-swap="innerHTML">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="danger has-tooltip" aria-describedby="archive-help" data-tooltip="Move this item to the archive and release its claim.">Archive</button></form>
        <span id="archive-help" class="visually-hidden">Move this item to the archive and release its claim.</span>
      </div>
      <div class="actions-primary">
        @if (Model.CanQueueForWorker)
        {
          <form hx-post="/?handler=QueueForWorker" hx-target="#item-panel" hx-swap="innerHTML" data-confirm-message="Queue this paused session for a continuous worker? The work item instructions will not be changed.">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="primary">Queue for worker</button></form>
        }
        <form hx-get="/?handler=Edit" hx-target="#item-panel" hx-swap="innerHTML"><input type="hidden" name="id" value="@Model.Id"><button class="@(Model.CanQueueForWorker ? null : "primary")">Edit</button></form>
      </div>
    }
    else if (Model.TakeoverAvailable)
    {
      <div class="actions-secondary">
        <form hx-post="/?handler=OverrideRelease" hx-target="#item-panel" hx-swap="innerHTML" data-confirm-message="Release the existing claim? The previous claimant may still have work in progress, and this does not stop its process. A recorded agent session remains available.">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button>Release existing claim…</button></form>
      </div>
      <div class="actions-primary">
        @if (Model.CanQueueForWorker)
        {
          <form hx-post="/?handler=QueueForWorker" hx-target="#item-panel" hx-swap="innerHTML" data-confirm-message="Queue this paused session for a continuous worker? The work item instructions will not be changed.">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="primary">Queue for worker</button></form>
        }
        <form hx-post="/?handler=Takeover" hx-target="#item-panel" hx-swap="innerHTML" data-confirm-message="@(Model.Activity == WorkItemActivities.NeedsAttention ? "Take over the paused session for editing? This rotates the retained claim and fences later cooperating Wrighty mutations from the previous claimant." : "Take over for editing? This does not stop the previous process. Later cooperating Wrighty mutations will be rejected, but a mutation already executing may finish first.")">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"><button class="primary">Take over for editing…</button></form>
      </div>
    }
  </footer>
</article>
