@model ItemPageModel
<article class="detail" data-item-id="@Model.Id">
  <header class="detail-header">
    <div><span class="display-id">@Model.DisplayId</span><h2 tabindex="-1">@Model.Title</h2></div>
    <button type="button" class="close-panel" aria-label="Close details">×</button>
  </header>
  @if (Model.Notice is not null){<p class="notice" role="status">@Model.Notice</p>}
  @if (Model.ErrorCode is not null){<p class="error" role="alert"><strong>@Model.ErrorCode</strong> @Model.ErrorMessage</p>}
  @if (Model.WebMutationProtectionMessage is not null){<p class="notice" role="status">@Model.WebMutationProtectionMessage</p>}
  <dl class="metadata"><div><dt>Status</dt><dd>@(Model.Status ?? "No status")</dd></div><div><dt>Priority</dt><dd>@(Model.Priority ?? "None")</dd></div>@if(Model.ClaimantKindLabel is not null){<div><dt>Claimant</dt><dd>@Model.ClaimantKindLabel</dd></div>}@if(Model.AgentTypeLabel is not null){<div><dt>Agent</dt><dd>@Model.AgentTypeLabel</dd></div>}<div><dt>Claim</dt><dd>@Model.ClaimLabel</dd></div></dl>
  <div class="tabs" role="tablist" aria-label="Markdown view">
    <button id="rendered-tab" type="button" class="tab active" role="tab" aria-selected="true" aria-controls="rendered-panel">Rendered</button>
    <button id="raw-tab" type="button" class="tab" role="tab" aria-selected="false" aria-controls="raw-panel" tabindex="-1">Raw Markdown</button>
  </div>
  <div id="rendered-panel" class="markdown" role="tabpanel" aria-labelledby="rendered-tab" hx-disable>@Model.RenderedBody</div>
  <pre id="raw-panel" class="raw" role="tabpanel" aria-labelledby="raw-tab" hidden><code>@Model.Body</code></pre>
  <footer class="actions">
    @if (Model.Archived)
    {
      <div class="actions-primary">
        <form hx-post="/?handler=Unarchive" hx-target="#item-panel" hx-swap="innerHTML"><input type="hidden" name="id" value="@Model.Id"><button class="primary">Unarchive</button></form>
      </div>
    }
    else if (Model.ClaimState == ClaimOwnershipState.Unclaimed)
    {
      <div class="actions-primary">
        <form hx-post="/?handler=Claim" hx-target="#item-panel" hx-swap="innerHTML"><input type="hidden" name="id" value="@Model.Id"><button class="primary">Claim for editing</button></form>
      </div>
    }
    else if (Model.ClaimState == ClaimOwnershipState.OwnedByCurrent && !Model.WebMutationProtected)
    {
      <div class="actions-secondary">
        <form hx-post="/?handler=Release" hx-target="#item-panel" hx-swap="innerHTML"><input type="hidden" name="id" value="@Model.Id"><button class="has-tooltip" aria-describedby="release-help" data-tooltip="Release the claim so another worker can claim this item.">Release</button></form>
        <span id="release-help" class="visually-hidden">Release the claim so another worker can claim this item.</span>
        <form hx-post="/?handler=Archive" hx-target="#item-panel" hx-swap="innerHTML"><input type="hidden" name="id" value="@Model.Id"><button class="danger has-tooltip" aria-describedby="archive-help" data-tooltip="Move this item to the archive and release its claim.">Archive</button></form>
        <span id="archive-help" class="visually-hidden">Move this item to the archive and release its claim.</span>
      </div>
      <div class="actions-primary">
        <form hx-get="/?handler=Edit" hx-target="#item-panel" hx-swap="innerHTML"><input type="hidden" name="id" value="@Model.Id"><button class="primary">Edit</button></form>
      </div>
    }
  </footer>
</article>
