@page
@model Highbyte.Wrighty.Web.Pages.IndexModel
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="htmx-config" content='{"allowEval":false,"allowScriptTags":false,"historyCacheSize":0,"selfRequestsOnly":true,"includeIndicatorStyles":false,"timeout":3000}'>
  <title>Wrighty dashboard</title>
  <link rel="stylesheet" href="/assets/wrighty.css">
  <script defer src="/assets/htmx.js"></script>
  <script type="module" src="/assets/app.js"></script>
</head>
<body>
  <header class="app-header">
    <div><span class="eyebrow">LOCAL MARKDOWN</span><h1>Wrighty</h1></div>
    <div id="connection-status" class="connection" role="status">Connecting…</div>
  </header>
  <main>
    <section class="toolbar" aria-label="Dashboard controls">
      <form id="board-filters" hx-get="/?handler=Board" hx-target="#board-content" hx-swap="outerHTML">
        <label>Search <input id="board-search" type="search" autocomplete="off" placeholder="ID, title, status, or priority"></label>
        <label>Scope
          <select name="scope">
            <option value="active">Active</option>
            <option value="archived">Archived</option>
            <option value="all">All</option>
          </select>
        </label>
        <button type="button" id="refresh-board">Refresh</button>
      </form>
      <p id="filter-status" class="filter-status" role="status" aria-live="polite"></p>
    </section>
    <section id="board-content" class="board-loading"
             aria-live="polite"
             hx-get="/?handler=Board"
             hx-trigger="wrighty:ready, wrighty:refresh"
             hx-include="#board-filters"
             hx-swap="outerHTML">Loading dashboard…</section>
  </main>
  <aside id="item-panel" class="item-panel" role="dialog" aria-modal="false" aria-label="Work item details" tabindex="-1"></aside>
</body>
</html>
