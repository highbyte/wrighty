{
  "backend": "local-markdown",
  "defaultPickFrom": "Todo",
  "defaultPickTo": "In Progress",
  "defaultFinishTo": "Done",
  "leaseMinutes": 60,
  "archive": {
    "onStatuses": [
      "Done"
    ]
  },
  "web": {
    "protectNonHumanClaims": true
  },
  "worker": {
    "defaultAgent": null,
    "workspaceMode": "current",
    "completion": {
      "commit": "inspect",
      "integration": "none"
    }
  },
  "localMarkdown": {
    "path": ".wrighty",
    "statuses": [
      "Todo",
      "In Progress",
      "Done"
    ],
    "priorities": [
      "P0",
      "P1",
      "P2",
      "P3"
    ]
  }
}
